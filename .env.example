# =============================================================================
# ENVIRONMENT TEMPLATE — commit this file, never commit .env
# Copy to .env and fill in real values before running tests locally.
# =============================================================================

# The base URL of the application under test.
# Swap between environments without touching test code:
#   staging:    BASE_URL=https://staging.saucedemo.com
#   production: BASE_URL=https://www.saucedemo.com
BASE_URL=https://www.saucedemo.com

# Human-readable label shown in test report metadata
TEST_ENV=local

# Default test user credentials.
# In CI, override these via GitHub Actions secrets (Settings → Secrets).
STANDARD_USER=standard_user
STANDARD_PASSWORD=secret_sauce
